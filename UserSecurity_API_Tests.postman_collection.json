							"pm.collectionVariables.set('user1_password', 'pass_' + r1);",
							"pm.collectionVariables.set('user1_firstName', 'FirstName_' + r1);",
							"pm.collectionVariables.set('user1_lastName', 'LastName_' + r1);"
